{% set opSecretPath = "op://homelab kubernetes/talos" %}
---
machine:
  install:
    image: factory.talos.dev/metal-installer/{{ ENV.TALOS_SCHEMATIC_AMD }}:{{ ENV.TALOS_VERSION }}
    diskSelector:
      serial: S7LANS0L509457M
  network:
    hostname: w03.k8s.batcave
    interfaces:
      - interface: bond0
        bond:
          deviceSelectors:
            - hardwareAddr: "38:05:25:36:7f:03"
              driver: i40e
            - hardwareAddr: "38:05:25:36:7f:04"
              driver: i40e
          mode: 802.3ad
          xmitHashPolicy: layer3+4
          lacpRate: fast
          miimon: 1000
        dhcp: true
        mtu: 1500
        vlans:
          - vlanId: 20
            dhcp: false
            mtu: 1500
          - vlanId: 50
            dhcp: false
            mtu: 1500
  nodeLabels:
    gpu.homelab/amd: "true"
---
apiVersion: v1alpha1
kind: EthernetConfig
name: enp5s0f0np0
rings:
  rx: 4096
---
apiVersion: v1alpha1
kind: EthernetConfig
name: enp5s0f1np1
rings:
  rx: 4096
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: local-hostpath
provisioning:
  diskSelector:
    match: disk.serial == "S7L9NJ0L408364D" && !system_disk
  minSize: 2.0TB
