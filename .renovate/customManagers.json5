{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Process annotated dependencies",
      managerFilePatterns: ["/(^|/).+\\.ya?ml(?:\\.j2)?$/"],
      matchStrings: [
        // # renovate: datasource=github-releases depName=kubernetes/kubernetes
        // version: 1.29.1
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+ (?<currentValue>[v|\\d]\\S+)",
        // # renovate: datasource=github-releases depName=example/project
        // https://github.com/example/project/releases/download/v0.1.0/crd.yaml
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+/(?<currentValue>[v|\\d][^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
    {
      customType: "regex",
      description: "Update the paired tag and digest for Bug Bounty release images",
      managerFilePatterns: [
        "/(^|/)kubernetes/apps/unbound-xi/bug-bounty/secrets/release\\.yaml$/",
      ],
      matchStrings: [
        "  # renovate-release: depName=(?<depName>\\S+)\\n  (?<versionKey>[A-Z0-9_]+_VERSION): (?<currentValue>\\S+)\\n  (?<digestKey>[A-Z0-9_]+_DIGEST): (?<currentDigest>sha256:[a-f0-9]+)",
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "semver",
      autoReplaceStringTemplate: "  # renovate-release: depName={{{depName}}}\n  {{{versionKey}}}: {{{newValue}}}\n  {{{digestKey}}}: {{{newDigest}}}",
    },
  ],
}
